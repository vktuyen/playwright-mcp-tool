# TrackerGo / Microsoft SSO credentials
# Used by Claude to auto-fill the login form when the browser session expires.
# MFA (Authenticator app) still requires manual approval.
#
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
# .env is gitignored — never commit it.

TRACKERGO_EMAIL=your-email@joblogic.com
TRACKERGO_PASSWORD=your-password
